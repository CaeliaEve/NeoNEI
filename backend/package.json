{
  "name": "neonei-backend",
  "version": "1.0.0",
  "description": "NeoNEI - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec \"node --max-old-space-size=4096 -r ts-node/register\" src/server.ts",
    "build": "tsc",
    "start": "node --max-old-space-size=4096 dist/server.js",
    "db:init": "ts-node src/scripts/init-database.ts",
    "verify-summaries": "ts-node src/scripts/quick-test-summaries.ts",
    "prewarm:recipe-bootstrap": "ts-node src/scripts/prewarm-recipe-bootstrap.ts",
    "test:pattern-export-contract": "node --test scripts/pattern-export-contract.test.mjs",
    "test:pattern-route-contract": "node --test scripts/pattern-route-contract.test.mjs",
    "gate:p0:recipe": "npm run build && npm run regression:api",
    "smoke": "node scripts/smoke-test.mjs",
    "regression:api": "node scripts/regression-api.mjs"
  },
  "keywords": [
    "ae2",
    "pattern-encoder",
    "minecraft",
    "gtnh"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "JSONStream": "^1.3.5",
    "pinyin-pro": "^3.28.0",
    "sql.js": "^1.10.3",
    "stream-chain": "^3.4.0",
    "stream-json": "^1.9.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "@types/sql.js": "^1.4.5",
    "@types/stream-chain": "^2.1.0",
    "@types/stream-json": "^1.7.8",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
