PORT=3002
HOST=0.0.0.0
# Optional external URL used in logs/output links
# PUBLIC_BASE_URL=http://localhost:3002
# Path env vars are strongly recommended in production.
# Backend has fallback auto-discovery for local/dev, but explicit config is safer.
IMAGES_PATH=/app/nesql-repository/image
DATA_DIR=/app/data
DB_FILE=/app/data/database.db
REBUILD_PROGRESS_FILE=/app/data/rebuild-progress.json
RECIPE_SUMMARIES_FILE=/app/data/recipe_summaries.csv
LOG_DIR=/app/data/logs
LOG_TO_CONSOLE=1
NESQL_REPOSITORY_PATH=/app/nesql-repository
NESQL_SPLIT_ITEMS_DIR=/app/nesql-repository/items
NESQL_SPLIT_RECIPES_DIR=/app/nesql-repository/recipes
NESQL_IMAGES_DIR=/app/nesql-repository/image/item
NESQL_CANONICAL_DIR=/app/nesql-repository/canonical
